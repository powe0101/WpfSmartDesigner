<Window x:Class="WpfSmartDesigner.Engine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WPF Smart Designer - AI Engine" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="15" CornerRadius="5" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="🤖 WPF Smart Designer AI Engine" 
                          FontSize="20" FontWeight="Bold" 
                          Foreground="White"/>
                <TextBlock Text="{Binding StatusText}" 
                          FontSize="14" 
                          Foreground="#A0A0A0" 
                          Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Stats Panel -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="15" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Requests Received" FontSize="12" Foreground="#666"/>
                    <TextBlock Text="{Binding RequestCount}" FontSize="24" FontWeight="Bold" Foreground="#007ACC"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Analyses Completed" FontSize="12" Foreground="#666"/>
                    <TextBlock Text="{Binding AnalysisCount}" FontSize="24" FontWeight="Bold" Foreground="#28A745"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Pipe Status" FontSize="12" Foreground="#666"/>
                    <TextBlock Text="{Binding PipeStatus}" FontSize="24" FontWeight="Bold" Foreground="#FFC107"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Log Output -->
        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox Text="{Binding LogText, Mode=OneWay}" 
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="#1E1E1E"
                         Foreground="#D4D4D4"
                         Padding="10"
                         BorderThickness="0"/>
            </ScrollViewer>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="📸 Test Screen Capture" 
                    Click="CaptureScreen_Click"
                    Padding="15,8"
                    Margin="0,0,10,0"
                    Background="#007ACC"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="🗑️ Clear Log" 
                    Click="ClearLog_Click"
                    Padding="15,8"
                    Background="#6C757D"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
